# devin-remediator configuration
# Copy to `.env` and fill in. Loaded automatically via dotenv.
# Do NOT commit your filled-in .env — it's gitignored.

# -- required ----------------------------------------------------------------

# GitHub personal-access token with `repo` scope (fork, create repos, file
# issues, open PRs, add labels). Create at:
#   https://github.com/settings/tokens/new?scopes=repo&description=devin-remediator
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Devin v3 service-user API key. Must start with cog_/dsk_/dev_.
# Generate at https://app.devin.ai/settings/service-users
DEVIN_API_KEY=cog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Prefixed UUID of your Devin org. Copy from the URL when logged in:
#   https://app.devin.ai/orgs/<ORG_ID>/...
# NOT the human-readable org display name.
DEVIN_ORG_ID=org-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your personal Devin user id, used for session attribution via
# create_as_user_id (falls back to service user on 403). Format is
# `user-…` or `email|…`, NOT your display name.
DEVIN_USER_ID=email|xxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repo whose issues you want remediated (Devin opens PRs here).
TARGET_REPO=yeutterg/superset

# -- optional ----------------------------------------------------------------

# Where STATUS.md is committed and pushed. Defaults to TARGET_REPO.
REMEDIATOR_REPO=yeutterg/devin-remediator

# Override the Devin API base. Rarely needed.
# DEVIN_API_BASE=https://api.devin.ai/v3

# Local checkout of the target repo, used by local scanners (pip-audit etc.).
# Only needed if you run `remediator scan`.
# TARGET_CHECKOUT=/home/ubuntu/repos/superset

# Path to the persistent state file (sessions, issues, caches).
# REMEDIATOR_STATE=./state.json

# Concurrent Devin sessions cap (the API also enforces an org cap).
# MAX_ACTIVE_SESSIONS=5

# Per-session ACU budget passed as max_acu_limit.
# MAX_ACU_PER_SESSION=8

# Label used by `issues:ingest` to identify which GitHub issues to pick up.
# AUTO_REMEDIATE_LABEL=devin-auto-remediate

# Print actions without hitting the Devin/GitHub APIs.
# DRY_RUN=false

# -- webhook-only (only if you're running `remediator webhook`) --------------

# Shared secret Devin will send in `x-devin-signature` or
# `x-webhook-secret`. Generate with: `openssl rand -hex 32`.
# WEBHOOK_SECRET=

# Branch of REMEDIATOR_REPO to auto-commit+push STATUS.md to on each event.
# Equivalent to passing `--push-branch` on the CLI. Leave empty to disable.
# WEBHOOK_PUSH_BRANCH=main

# -- loop-only (only if you're running `scripts/loop.sh`) -------------------

# Seconds between ticks.
# INTERVAL=60

# Branch to push STATUS.md updates to.
# BRANCH=main

# 0 to skip dispatch each tick (reconcile/report only).
# LOOP_DISPATCH=1

# 1 = one-at-a-time pacing: pins MAX_ACTIVE_SESSIONS=1 so only one Devin session runs
# at a time (a new session only starts after the previous session's PR ships and its
# slot is released). Useful for Loom recordings.
# LOOP_DEMO=0
